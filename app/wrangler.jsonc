{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gds-product-map",
  "main": "worker/index.js",
  "compatibility_date": "2026-06-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/auth",
      "/callback",
      "/api/*"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
